{
  "name": "Student Activity Attendance and Monitoring System Application",
  "short_name": "Syamsa",
  "description": "Aplikasi absensi dan pemantauan kegiatan pelajar",
  "version": "2.2.9",
  "id": "syamsa-pwa",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#0C4E8C",
