      "description": "Lihat laporan",
      "url": "/#report",
      "icons": [{ "src": "assets/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Profil",
      "short_name": "Profil",
      "description": "Profil saya",
      "url": "/#profile",
      "icons": [{ "src": "assets/icons/icon-192.png", "sizes": "192x192" }]
